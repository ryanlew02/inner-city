{
  "expo": {
    "name": "Inner City",
    "slug": "InnerCity",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo_ios.png",
    "scheme": "innercity",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/logo_ios.png",
      "resizeMode": "contain",
      "backgroundColor": "#121218"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ryanlewandowski.innercity"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo_android.png",
        "backgroundColor": "#121218"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [],
      "package": "com.ryanlewandowski.innercity"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo_ios.png"
    },
    "plugins": [
      "expo-router",
      "expo-audio",
      "expo-notifications",
      "expo-sqlite",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
