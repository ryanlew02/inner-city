{
  "expo": {
    "name": "Inner City",
    "slug": "InnerCity",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo_ios.png",
    "scheme": "innercity",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/logo_ios.png",
      "resizeMode": "contain",
      "backgroundColor": "#121218"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ryanlewandowski.innercity",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "3"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo_android.png",
        "backgroundColor": "#121218"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.ryanlewandowski.innercity"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo_ios.png"
    },
    "plugins": [
      "expo-router",
      "expo-audio",
      "expo-notifications",
      "expo-sqlite",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1a205e5b-3cba-46b7-8b3d-79f756a618f8"
      }
    }
  }
}
